# --- FONCTIONS UTILITAIRES ---

def session_active():
    h = datetime.utcnow().hour
    actives = []
    for name, (start, end) in SESSIONS.items():
        if start < end:
            if start <= h < end: actives.append(name)
        else:
            if h >= start or h < end: actives.append(name)
    return actives

def paires_session():
    actives = session_active()
    paires = set(PAIRES_ORIGINAL)
    if "Sydney" in actives: paires.update(PAIRES_SYDNEY)
    if "Tokyo" in actives: paires.update(PAIRES_TOKYO)
    if "Londres" in actives: paires.update(PAIRES_LONDRES)
    if "NewYork" in actives: paires.update(PAIRES_NEWYORK)
    return list(paires)

def charger_journal():
    aujourd_hui = str(date.today())
    if os.path.exists(JOURNAL_FILE):
        with open(JOURNAL_FILE, "r") as f:
            data = json.load(f)
            if data.get("date") == aujourd_hui:
                return data
    journal = {
        "date": aujourd_hui,
        "trades_jour": 0,
        "gain_jour_eur": 0.0,
        "bot_actif": True,
        "historique": []
    }
    sauvegarder_journal(journal)
    return journal

def sauvegarder_journal(j):
    with open(JOURNAL_FILE, "w") as f:
        json.dump(j, f, indent=2, ensure_ascii=False)

